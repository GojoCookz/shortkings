# Copy this file to .env.local and fill in your Supabase project values.
# Find these in: Supabase Dashboard → Project Settings → API

# Safe to expose to the browser:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Public base URL of the deployed site (used to build share links + auth redirects).
# Local dev: http://localhost:3000  |  Prod: https://shortkings-dass.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SERVER ONLY — never exposed to the client, never committed.
# Not needed for the Phase 1 referral flow; reserved for admin/cron tasks (Phase 2+).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
